<!DOCTYPE html>
<html>
<head>
    <title>Edit</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<h1>Edit Post</h1>

<form action="/update/<%= post.id %>" method="POST">
    <input type="text" name="title" value="<%= post.title %>">
    <textarea name="content"><%= post.content %></textarea>
    <button type="submit">Update</button>
</form>

</body>
</html>